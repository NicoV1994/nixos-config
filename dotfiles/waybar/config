{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "cpu",
    "memory",
  ],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "custom/mic",
    "pulseaudio",
    "battery",
    "custom/network",
    "clock",
  ],
  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "",
      "default": ""
    }
  },
  "clock": {
    "timezone": "Europe/Vienna",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "KW {:%V - %d.%m.%Y - %H:%M}"
  },
  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%",
    "tooltip": false
  },
  "custom/network": {
    "exec": "bash ~/.config/waybar/scripts/network-status.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "bash ~/.config/waybar/scripts/vpn-menu.sh",
    "on-click-right": "nm-connection-editor"
  },
  "cpu": {
    "interval": 1,
    "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
  },
  "memory": {
    "interval": 30,
    "format": "  {used:0.1f}G/{total:0.1f}G"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "",
    "format-icons": {
      "default": ["", "", " "]
    },
    "on-click": "pavucontrol"
  },
  "custom/mic": {
    "exec": "bash ~/.config/waybar/scripts/mic-status.sh",
    "return-type": "json",
    "interval": 2,
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
  },
  "later": {
    "format": "<span class='icon'>{icon}</span> <span class='text'>{text}</span>"
  }
}
